<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Personality Discovery Bot</title>
  <style>
    * { box-sizing: border-box; }
    body {
      margin: 0;
      font-family: Arial, sans-serif;
      background: linear-gradient(135deg, #f5f7fb, #e9eef8);
      color: #1f2937;
    }
    .wrap {
      max-width: 860px;
      margin: 40px auto;
      padding: 20px;
    }
    .card {
      background: #fff;
      border-radius: 20px;
      box-shadow: 0 10px 30px rgba(0,0,0,0.08);
      padding: 28px;
    }
    h1 {
      margin-top: 0;
      font-size: 2rem;
      color: #172554;
    }
    .sub {
      color: #475569;
      line-height: 1.6;
      margin-bottom: 18px;
    }
    .disclaimer {
      background: #eff6ff;
      border-left: 4px solid #2563eb;
      padding: 12px 14px;
      border-radius: 10px;
      margin-bottom: 20px;
      color: #1e3a8a;
      font-size: 0.95rem;
    }
    .progress-row {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 12px;
      margin: 22px 0 16px;
    }
    .progress-text {
      font-weight: 700;
      color: #334155;
      min-width: 110px;
    }
    .progress {
      flex: 1;
      height: 12px;
      background: #e5e7eb;
      border-radius: 999px;
      overflow: hidden;
    }
    .bar {
      height: 100%;
      width: 0%;
      background: linear-gradient(90deg, #2563eb, #7c3aed);
      transition: width 0.3s ease;
    }
    .question-box {
      background: #f8fafc;
      border: 1px solid #e2e8f0;
      border-radius: 16px;
      padding: 22px;
      margin-top: 10px;
    }
    .trait {
      display: inline-block;
      background: #e0e7ff;
      color: #3730a3;
      padding: 7px 12px;
      border-radius: 999px;
      font-size: 0.85rem;
      font-weight: 700;
      margin-bottom: 12px;
    }
    .question {
      font-size: 1.25rem;
      line-height: 1.5;
      margin-bottom: 18px;
      font-weight: 700;
    }
    .options {
      display: grid;
      gap: 10px;
    }
    .option-btn {
      width: 100%;
      text-align: left;
      padding: 14px 16px;
      border: 1px solid #cbd5e1;
      background: #fff;
      border-radius: 12px;
      cursor: pointer;
      font-size: 1rem;
      transition: all 0.18s ease;
    }
    .option-btn:hover {
      background: #eff6ff;
      border-color: #60a5fa;
      transform: translateY(-1px);
    }
    .muted {
      color: #64748b;
      font-size: 0.95rem;
      margin-top: 14px;
    }
    .hidden { display: none; }

    .result-title {
      font-size: 1.8rem;
      color: #111827;
      margin-bottom: 10px;
    }
    .summary {
      background: #f8fafc;
      border-radius: 16px;
      padding: 18px;
      line-height: 1.7;
      margin: 18px 0 22px;
      border: 1px solid #e2e8f0;
    }
    .scores {
      display: grid;
      gap: 14px;
      margin-top: 16px;
    }
    .score-card {
      border: 1px solid #e5e7eb;
      border-radius: 14px;
      padding: 16px;
      background: #fff;
    }
    .score-head {
      display: flex;
      justify-content: space-between;
      font-weight: 700;
      margin-bottom: 10px;
    }
    .score-track {
      height: 12px;
      background: #e5e7eb;
      border-radius: 999px;
      overflow: hidden;
      margin-bottom: 10px;
    }
    .score-fill {
      height: 100%;
      border-radius: 999px;
      background: linear-gradient(90deg, #0ea5e9, #8b5cf6);
    }
    .desc {
      color: #475569;
      line-height: 1.55;
    }
    .btn-row {
      display: flex;
      gap: 12px;
      flex-wrap: wrap;
      margin-top: 24px;
    }
    .btn {
      border: none;
      padding: 14px 18px;
      border-radius: 12px;
      cursor: pointer;
      font-size: 1rem;
      font-weight: 700;
    }
    .primary {
      background: #2563eb;
      color: #fff;
    }
    .secondary {
      background: #e2e8f0;
      color: #0f172a;
    }
    .footer-note {
      margin-top: 22px;
      color: #64748b;
      font-size: 0.9rem;
      line-height: 1.5;
    }
    @media (max-width: 640px) {
      .card { padding: 18px; }
      .question { font-size: 1.1rem; }
      h1 { font-size: 1.6rem; }
    }
  </style>
</head>
<body>
  <div class="wrap">
    <div class="card">
      <div id="introScreen">
        <h1>Personality Discovery Bot</h1>
        <p class="sub">
          Answer 25 research-inspired questions to get a personal profile based on
          major personality dimensions often studied in academic psychology.
        </p>
        <div class="disclaimer">
          This is a Harvard-style, research-inspired personality quiz using themes commonly studied in psychology,
          especially the Big Five. It is not an official Harvard assessment or medical diagnosis.
        </div>
        <div class="btn-row">
          <button class="btn primary" onclick="startQuiz()">Start the 25 Questions</button>
        </div>
      </div>

      <div id="quizScreen" class="hidden">
        <div class="progress-row">
          <div class="progress-text" id="progressText">Question 1 of 25</div>
          <div class="progress">
            <div class="bar" id="progressBar"></div>
          </div>
        </div>

        <div class="question-box">
          <div class="trait" id="traitLabel">Trait</div>
          <div class="question" id="questionText"></div>
          <div class="options" id="options"></div>
          <div class="muted">
            Scale: 1 = Strongly Disagree, 2 = Disagree, 3 = Neutral, 4 = Agree, 5 = Strongly Agree
          </div>
        </div>
      </div>

      <div id="resultScreen" class="hidden">
        <div class="result-title">Your Personality Profile</div>
        <div class="summary" id="summaryText"></div>
        <div class="scores" id="scoresContainer"></div>
        <div class="btn-row">
          <button class="btn primary" onclick="restartQuiz()">Retake Quiz</button>
          <button class="btn secondary" onclick="downloadResults()">Download Results</button>
        </div>
        <div class="footer-note">
          This result is best used as a self-reflection tool, not as a clinical or hiring decision instrument.
        </div>
      </div>
    </div>
  </div>

  <script>
    const questions = [
      // Openness
      { trait: "Openness", text: "I enjoy exploring new ideas and philosophies." },
      { trait: "Openness", text: "I like trying new activities even if they feel unfamiliar." },
      { trait: "Openness", text: "I often think about abstract or complex concepts." },
      { trait: "Openness", text: "I enjoy art, music, or creative expression." },
      { trait: "Openness", text: "I prefer variety rather than routine." },

      // Conscientiousness
      { trait: "Conscientiousness", text: "I plan my tasks carefully before starting them." },
      { trait: "Conscientiousness", text: "I usually complete tasks on time." },
      { trait: "Conscientiousness", text: "I pay attention to small details." },
      { trait: "Conscientiousness", text: "I set long-term goals and work toward them." },
      { trait: "Conscientiousness", text: "I stay organized even when life gets busy." },

      // Extraversion
      { trait: "Extraversion", text: "I feel energized when interacting with people." },
      { trait: "Extraversion", text: "I enjoy being the center of attention in group settings." },
      { trait: "Extraversion", text: "I find it easy to start conversations with strangers." },
      { trait: "Extraversion", text: "I prefer working with others rather than alone." },
      { trait: "Extraversion", text: "I often seek out social events or gatherings." },

      // Agreeableness
      { trait: "Agreeableness", text: "I try to understand other people's perspectives." },
      { trait: "Agreeableness", text: "I enjoy helping others succeed." },
      { trait: "Agreeableness", text: "I avoid conflict whenever possible." },
      { trait: "Agreeableness", text: "I consider myself compassionate." },
      { trait: "Agreeableness", text: "People often describe me as supportive." },

      // Emotional Stability
      { trait: "Emotional Stability", text: "I stay calm during stressful situations." },
      { trait: "Emotional Stability", text: "I recover quickly after setbacks." },
      { trait: "Emotional Stability", text: "I rarely feel overwhelmed by anxiety." },
      { trait: "Emotional Stability", text: "I can handle criticism without taking it personally." },
      { trait: "Emotional Stability", text: "I feel confident about my future." }
    ];

    const optionLabels = [
      { value: 1, label: "1 — Strongly Disagree" },
      { value: 2, label: "2 — Disagree" },
      { value: 3, label: "3 — Neutral" },
      { value: 4, label: "4 — Agree" },
      { value: 5, label: "5 — Strongly Agree" }
    ];

    let currentIndex = 0;
    let answers = [];

    function startQuiz() {
      currentIndex = 0;
      answers = [];
      document.getElementById("introScreen").classList.add("hidden");
      document.getElementById("resultScreen").classList.add("hidden");
      document.getElementById("quizScreen").classList.remove("hidden");
      renderQuestion();
    }

    function renderQuestion() {
      const q = questions[currentIndex];
      document.getElementById("progressText").textContent = `Question ${currentIndex + 1} of ${questions.length}`;
      document.getElementById("progressBar").style.width = `${((currentIndex) / questions.length) * 100}%`;
      document.getElementById("traitLabel").textContent = q.trait;
      document.getElementById("questionText").textContent = q.text;

      const options = document.getElementById("options");
      options.innerHTML = "";

      optionLabels.forEach(opt => {
        const btn = document.createElement("button");
        btn.className = "option-btn";
        btn.textContent = opt.label;
        btn.onclick = () => saveAnswer(opt.value);
        options.appendChild(btn);
      });
    }

    function saveAnswer(value) {
      answers.push({
        trait: questions[currentIndex].trait,
        question: questions[currentIndex].text,
        value: value
      });

      currentIndex++;

      if (currentIndex < questions.length) {
        renderQuestion();
      } else {
        showResults();
      }
    }

    function calculateScores() {
      const grouped = {};
      answers.forEach(a => {
        if (!grouped[a.trait]) grouped[a.trait] = [];
        grouped[a.trait].push(a.value);
      });

      const scores = {};
      Object.keys(grouped).forEach(trait => {
        const total = grouped[trait].reduce((sum, v) => sum + v, 0);
        scores[trait] = +(total / grouped[trait].length).toFixed(2);
      });

      return scores;
    }

    function scoreLevel(score) {
      if (score >= 4.2) return "Very High";
      if (score >= 3.5) return "High";
      if (score >= 2.6) return "Moderate";
      if (score >= 1.8) return "Low";
      return "Very Low";
    }

    function traitDescription(trait, score) {
      const level = scoreLevel(score);

      const map = {
        "Openness": {
          "Very High": "You are highly curious, imaginative, and open to new ideas, perspectives, and experiences.",
          "High": "You tend to enjoy creativity, learning, and intellectual exploration.",
          "Moderate": "You balance curiosity with practicality and may enjoy novelty in selected areas.",
          "Low": "You may prefer familiarity, clarity, and proven approaches over experimentation.",
          "Very Low": "You likely value routine, structure, and traditional ways of thinking."
        },
        "Conscientiousness": {
          "Very High": "You are exceptionally organized, dependable, disciplined, and goal-oriented.",
          "High": "You usually plan well, stay responsible, and follow through on commitments.",
          "Moderate": "You can be organized when needed but may stay flexible depending on the situation.",
          "Low": "You may prefer spontaneity over rigid planning and structure.",
          "Very Low": "You may struggle with routine, deadlines, or maintaining detailed organization."
        },
        "Extraversion": {
          "Very High": "You are highly socially energized, expressive, and likely enjoy frequent interaction.",
          "High": "You tend to be outgoing, comfortable with people, and socially engaged.",
          "Moderate": "You likely enjoy both social interaction and solo time depending on context.",
          "Low": "You may prefer quieter settings, smaller circles, and more personal space.",
          "Very Low": "You are likely deeply reserved, reflective, and more energized by solitude."
        },
        "Agreeableness": {
          "Very High": "You are highly empathetic, cooperative, warm, and considerate of others.",
          "High": "You are generally supportive, kind, and attentive to relationships.",
          "Moderate": "You balance compassion with practicality and boundaries.",
          "Low": "You may be more direct, skeptical, or independent in how you relate to others.",
          "Very Low": "You may prioritize logic and self-interest over harmony or emotional accommodation."
        },
        "Emotional Stability": {
          "Very High": "You tend to remain calm, resilient, and steady even under pressure.",
          "High": "You usually handle stress well and recover from setbacks effectively.",
          "Moderate": "You show a balanced emotional response and may vary by situation.",
          "Low": "You may be more emotionally reactive, self-critical, or stress-sensitive.",
          "Very Low": "You may experience stress, worry, or emotional strain more intensely than average."
        }
      };

      return map[trait][level];
    }

    function overallProfile(scores) {
      const sorted = Object.entries(scores).sort((a,b) => b[1] - a[1]);
      const top1 = sorted[0][0];
      const top2 = sorted[1][0];

      const pair = `${top1}|${top2}`;

      const profiles = {
        "Openness|Conscientiousness": "You come across as a Strategic Thinker — imaginative but also structured. You likely enjoy learning, planning, and turning ideas into action.",
        "Conscientiousness|Openness": "You come across as a Strategic Thinker — imaginative but also structured. You likely enjoy learning, planning, and turning ideas into action.",
        "Agreeableness|Conscientiousness": "You come across as a Reliable Supporter — dependable, considerate, and motivated to help people while keeping things organized.",
        "Conscientiousness|Agreeableness": "You come across as a Reliable Supporter — dependable, considerate, and motivated to help people while keeping things organized.",
        "Extraversion|Agreeableness": "You come across as a Warm Connector — social, supportive, and energized by relationships and community.",
        "Agreeableness|Extraversion": "You come across as a Warm Connector — social, supportive, and energized by relationships and community.",
        "Openness|Extraversion": "You come across as an Expressive Explorer — curious, energetic, and drawn to people, ideas, and new experiences.",
        "Extraversion|Openness": "You come across as an Expressive Explorer — curious, energetic, and drawn to people, ideas, and new experiences.",
        "Emotional Stability|Conscientiousness": "You come across as a Grounded Achiever — calm, dependable, and likely strong in high-pressure situations.",
        "Conscientiousness|Emotional Stability": "You come across as a Grounded Achiever — calm, dependable, and likely strong in high-pressure situations."
      };

      return profiles[pair] || `Your strongest dimensions are ${top1} and ${top2}. This suggests a personality pattern shaped by those traits in how you think, relate, and act.`;
    }

    function showResults() {
      document.getElementById("quizScreen").classList.add("hidden");
      document.getElementById("resultScreen").classList.remove("hidden");
      document.getElementById("progressBar").style.width = "100%";

      const scores = calculateScores();
      const summary = overallProfile(scores);

      const extras = [];
      Object.entries(scores).forEach(([trait, score]) => {
        extras.push(`${trait}: ${score}/5 (${scoreLevel(score)})`);
      });

      document.getElementById("summaryText").innerHTML = `
        <strong>${summary}</strong><br><br>
        Here is your score overview:<br>
        ${extras.map(x => `• ${x}`).join("<br>")}
      `;

      const container = document.getElementById("scoresContainer");
      container.innerHTML = "";

      Object.entries(scores).forEach(([trait, score]) => {
        const div = document.createElement("div");
        div.className = "score-card";
        div.innerHTML = `
          <div class="score-head">
            <span>${trait}</span>
            <span>${score}/5 • ${scoreLevel(score)}</span>
          </div>
          <div class="score-track">
            <div class="score-fill" style="width:${(score / 5) * 100}%"></div>
          </div>
          <div class="desc">${traitDescription(trait, score)}</div>
        `;
        container.appendChild(div);
      });
    }

    function restartQuiz() {
      document.getElementById("resultScreen").classList.add("hidden");
      document.getElementById("introScreen").classList.remove("hidden");
      currentIndex = 0;
      answers = [];
    }

    function downloadResults() {
      const scores = calculateScores();
      const text = `
Personality Discovery Bot Results

Summary:
${overallProfile(scores)}

Scores:
${Object.entries(scores).map(([trait, score]) => `${trait}: ${score}/5 (${scoreLevel(score)})`).join("\n")}

Detailed Notes:
${Object.entries(scores).map(([trait, score]) => `${trait}: ${traitDescription(trait, score)}`).join("\n\n")}

Note:
This is a research-inspired self-reflection tool and not an official Harvard assessment.
      `.trim();

      const blob = new Blob([text], { type: "text/plain" });
      const url = URL.createObjectURL(blob);
      const a = document.createElement("a");
      a.href = url;
      a.download = "personality-results.txt";
      a.click();
      URL.revokeObjectURL(url);
    }
  </script>
</body>
</html>
